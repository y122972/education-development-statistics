    {
      "section": "义务教育",
      "text": "全国实现“两基”的地区人口覆盖率进一步提高，达到90%以上。到2002年年底，实现“两基”验收的县(市、区)总数达到2598个(含其他县级行政区划单位169个)，比上年增加24个县(市、区)；12个省(直辖市)已按要求实现“两基”。",
      "values": [
        {
          "label": "实现两基地区人口覆盖率",
          "raw": "90%",
          "value": 90,
          "unit": "%"
        },
        {
          "label": "实现两基验收县市区数",
          "raw": "2598个",
          "value": 2598,
          "unit": "个"
        },
        {
          "label": "其中其他县级行政区划单位数",
          "raw": "169个",
          "value": 169,
          "unit": "个"
        },
        {
          "label": "实现两基验收县市区数比上年增加",
          "raw": "24个",
          "value": 24,
          "unit": "个"
        },
        {
          "label": "实现两基省直辖市数",
          "raw": "12个",
          "value": 12,
          "unit": "个"
        }
      ]
    },
